{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dgp.dev/schemas/v1.0/PolicyDecision.schema.json",
  "title": "DGP.PolicyDecision",
  "description": "The output of governance policy evaluation against an ActionRequest.",
  "type": "object",
  "required": ["dgp_version", "decision_id", "action_id", "status", "risk_score", "timestamp", "expires_at"],
  "properties": {
    "dgp_version": { "type": "string", "const": "1.0" },
    "decision_id": { "type": "string", "format": "uuid" },
    "action_id": { "type": "string", "format": "uuid" },
    "status": { "enum": ["APPROVED", "FLAGGED", "BLOCKED"] },
    "matched_policies": { "type": "array", "items": { "type": "string" } },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["policy_id", "severity", "message"],
        "properties": {
          "policy_id": { "type": "string" },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "message": { "type": "string", "maxLength": 512 }
        }
      }
    },
    "risk_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "reasoning": { "type": "string", "maxLength": 2048 },
    "requires_human_review": { "type": "boolean" },
    "budget_authorized": { "type": "boolean" },
    "spend_authorized": { "type": "string", "pattern": "^\\$[0-9]+\\.[0-9]{2}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
